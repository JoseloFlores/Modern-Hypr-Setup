{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 0,
    "output": "eDP-1",
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": ["mpris"],
    "modules-right": ["group/quicksettings", "clock", "custom/updates", "backlight", "tray", "group/power"],

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"],
        "on-scroll-up": "brightnessctl set 1%+",
        "on-scroll-down": "brightnessctl set 1%-",
        "min-length": 6
    },

    "group/quicksettings": {
        "orientation": "inherit",
        "modules": [
            "pulseaudio",
            "network",
            "bluetooth",
            "battery"
        ]
    },

    "mpris": {
        "format": "{player_icon} {title} - {artist} [{position}/{length}]",
        "format-paused": "{status_icon} <i>{title} - {artist}</i>",
        "player-icons": {
            "default": "тЦ╢",
            "spotify": "яЖ╝",
            "firefox": "яЙй"
        },
        "status-icons": {
            "paused": "тП╕"
        },
        "max-length": 40,
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl next",
        "on-click-middle": "playerctl previous",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous"
    },

    "group/power": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "children-class": "not-power",
            "transition-left-to-right": false
        },
        "modules": [
            "custom/power", 
            "custom/lock",
            "custom/reboot",
            "custom/quit"
        ]
    },
    "custom/power": {
        "format": "тП╗",
        "tooltip": false,
        "on-click": "~/.config/hypr/confirm_power.sh \"┬┐Apagar el sistema?\" \"shutdown now\""
    },
    "custom/quit": {
        "format": "ґ░Ч╝",
        "tooltip": false,
        "on-click": "~/.config/hypr/confirm_power.sh \"┬┐Cerrar sesi├│n?\" \"hyprctl dispatch exit\""
    },
    "custom/lock": {
        "format": "ґ░М╛",
        "tooltip": false,
        "on-click": "loginctl lock-session"
    },
    "custom/reboot": {
        "format": "ґ░ЬЙ",
        "tooltip": false,
        "on-click": "~/.config/hypr/confirm_power.sh \"┬┐Reiniciar el sistema?\" \"reboot\""
    },

    "custom/updates": {
        "format": "{text}",
        "interval": 3600,
        "return-type": "json",
        "exec": "~/.config/hypr/check_updates.sh",
        "on-click": "foot sh -c 'sudo apt update && sudo apt upgrade -y; pkill -SIGRTMIN+8 waybar; echo \"Sistema actualizado. Presiona cualquier tecla para cerrar...\"; read -n 1'",
        "signal": 8,
        "tooltip": false
    },

    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "format-icons": {
            "active": "яЖТ",
            "default": "яДМ"
        }
    },

    "hyprland/window": {
        "format": "{}",
        "max-length": 40,
        "separate-outputs": true
    },

    "tray": {
        "spacing": 10
    },

    "clock": {
        "timezone": "America/Argentina/Buenos_Aires",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt>{calendar}</tt>",
        "format": "яАЧ {:%H:%M  яБ│ %d/%m}",
        "calendar": {
            "mode"          : "month",
            "mode-mon-col"  : 3,
            "weeks-pos"     : "right",
            "on-scroll"     : 1,
            "format": {
                "months":     "<span color='#bb9af7'><b>{}</b></span>",
                "days":       "<span color='#c0caf5'><b>{}</b></span>",
                "weeks":      "<span color='#7dcfff'><b>W{}</b></span>",
                "weekdays":   "<span color='#e0af68'><b>{}</b></span>",
                "today":      "<span color='#f7768e'><b><u>{}</u></b></span>"
            }
        },
        "actions":  {
            "on-click": "shift_down",
            "on-click-middle": "shift_up",
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    "cpu": {
        "format": "яЛЫ {usage}%",
        "tooltip": false
    },

    "memory": {
        "format": "яГЙ {}%"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "яЧз {capacity}%",
        "format-plugged": "яЗж {capacity}%",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },

    "network": {
        "format-wifi": "яЗл",
        "format-ethernet": "яЮЦ",
        "tooltip-format": "яЮЦ {ifname} via {gwaddr}",
        "format-linked": "яЮЦ",
        "format-disconnected": "тЪа",
        "on-click": "adwaita-network"
    },

    "bluetooth": {
        "format": "яКФ {status}",
        "format-connected": "яКФ {device_alias}",
        "format-connected-battery": "яКФ {device_alias} {device_battery_percentage}%",
        "on-click": "blueman-manager"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon}яКФ {volume}% {format_source}",
        "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
        "format-muted": "яЪй {format_source}",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click": "pavucontrol"
    }
}
